{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ticketing",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "services/ticketing" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "services/ticketing" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "go run ./cmd", "cwd": "services/ticketing" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "golangci-lint run --allow-parallel-runners", "cwd": "services/ticketing" }
    }
  }
}
