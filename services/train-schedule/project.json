{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "train-schedule",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build ./...",
        "cwd": "services/train-schedule"
      },
      "dependsOn": [
        "libs-proto:codegen"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "services/train-schedule"
      },
      "dependsOn": [
        "libs-proto:codegen"
      ]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run ./cmd",
        "cwd": "services/train-schedule"
      },
      "dependsOn": [
        "libs-proto:codegen"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run --allow-parallel-runners",
        "cwd": "services/train-schedule"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o ../../dist/train-schedule ./cmd",
        "cwd": "services/train-schedule"
      }
    }
  }
}
