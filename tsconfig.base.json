{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "paths": {
      "@railway/ui-core": ["./packages/ui-core/src/index.ts"],
      "@railway/ui-web": ["./packages/ui-web/src/index.ts"],
      "@railway/ui-taro": ["./packages/ui-taro/src/index.ts"],
      "@railway/ui-native": ["./packages/ui-native/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp"]
}
