{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/**/*.config.[jt]s",
      "!{projectRoot}/**/*_test.go",
      "!{projectRoot}/tests/**/*",
      "!{projectRoot}/e2e/**/*"
    ],
    "sharedGlobals": ["{workspaceRoot}/go.work", "{workspaceRoot}/tsconfig.base.json"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "package": {
      "dependsOn": ["libs-proto:codegen", "^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/{projectName}"],
      "cache": true
    },
    "test": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "codegen": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    }
  }
}
