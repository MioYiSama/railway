{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "libs-config",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "libs/config" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "libs/config" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run --allow-parallel-runners",
        "cwd": "libs/config"
      }
    }
  }
}
