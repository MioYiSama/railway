{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "libs-proto",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "libs/proto" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "libs/proto" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "GOCACHE=\"$PWD/../../.cache/go-build\" GOMODCACHE=\"$PWD/../../.cache/go-mod\" buf generate",
        "cwd": "libs/proto"
      },
      "outputs": ["{workspaceRoot}/libs/proto/gen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "libs/proto"
      }
    }
  }
}
