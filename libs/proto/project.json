{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "libs-proto",
  "projectType": "library",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf generate",
        "cwd": "libs/proto"
      },
      "outputs": ["{workspaceRoot}/libs/gen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "libs/proto"
      }
    }
  }
}
