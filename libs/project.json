{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "libs",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "libs" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "libs" },
      "dependsOn": ["libs-proto:codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "golangci-lint run --allow-parallel-runners", "cwd": "libs" }
    }
  }
}
