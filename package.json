{
  "name": "railway",
  "version": "0.0.0",
  "private": true,
  "description": "railway monorepo (学习用途)",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "GOCACHE=\"$PWD/.cache/go-build\" GOLANGCI_LINT_CACHE=\"$PWD/.cache/golangci-lint\" nx run-many -t lint",
    "codegen": "nx run libs-proto:codegen",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@nx/js": "23.0.0",
    "@nx/vite": "23.0.0",
    "@playwright/test": "1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "29.1.1",
    "nx": "23.0.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
